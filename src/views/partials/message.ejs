<div class="flex <%= message.role === 'user' ? 'justify-end' : 'justify-start' %>">
  <article class="max-w-[80%] rounded-2xl px-4 py-3 shadow-lg <%= message.role === 'user' ? 'bg-sky-500 text-white' : 'border border-zinc-700 bg-zinc-800 text-zinc-100' %>">
    <p class="whitespace-pre-wrap text-sm leading-6"><%= message.content %></p>
  </article>
</div>
